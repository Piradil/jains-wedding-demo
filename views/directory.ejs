    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
        [x-cloak] { display: none !important; }
        
        /* Infinitely Looping Ticker Animation Styles */
        @keyframes marquee {
            0% { transform: translateX(0%); }
            100% { transform: translateX(-50%); }
        }
        .animate-marquee {
            display: flex;
            width: max-content;
            animation: marquee 25s linear infinite;
        }
        .animate-marquee:hover {
            animation-play-state: paused;
        }

        /* --- Custom Flashlight Reveal Source CSS Engine --- */
        @keyframes flashlightMove {
            0% { transform: translate(-25%, -15%); }
            50% { transform: translate(105%, 15%); }
            100% { transform: translate(-25%, -15%); }
        }

        .reveal-wrapper {
            position: relative;
            display: block;
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
        }

        .text-base-layer {
            color: rgba(255, 255, 255, 0.08);
            user-select: none;
            width: 100%;
        }

        .text-reveal-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            color: #ffffff;
            -webkit-mask-image: radial-gradient(circle 110px at 0 0, #fff 100%, transparent 100%);
            mask-image: radial-gradient(circle 110px at 0 0, #fff 100%, transparent 100%);
            -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
            animation: flashlightMove 6.5s ease-in-out infinite;
        }

        .amber-highlight {
            background: linear-gradient(to right, #fbbf24, #fb923c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Responsive Video Embed Fix */
        .aspect-video iframe {
            width: 100% !important;
            height: 100% !important;
            border-radius: 0.75rem;
        }

        /* --- Your Exact Source Layout CSS Styles --- */
        .hideBtn {
            position: absolute;
            right: 50px;
            bottom: 60px;
            font-family: Tahoma, Geneva, sans-serif;
            color: rgb(255, 255, 255);
            font-size: 1.3vw;
            cursor: pointer;
            user-select: none;
            padding: 10px 22px;
            border-radius: 12px;
            background: rgb(0, 0, 0);
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: color .7s, background .4s;
            z-index: 30;
        }

        .hideBtn:hover {
            color: rgb(255, 229, 181);
            background: rgb(20, 20, 20);
        }

        .infoText {
            position: absolute;
            left: 0;
            bottom: 0;
            padding: 14px 10px;
            width: 100%;
            background: rgba(22, 22, 22, 0.85);
            backdrop-blur: md;
            text-align: center;
            font-family: Tahoma, Geneva, sans-serif;
            color: rgba(255, 255, 255, 0.74);
            font-size: 14px;
            letter-spacing: 0.05em;
            z-index: 25;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }
