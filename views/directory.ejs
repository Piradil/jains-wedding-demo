                 x-show="promiseVisible" x-transition:enter="transition ease-out duration-1000 transform delay-200" x-transition:enter-start="opacity-0 scale-95">
                
                <!-- Main Luxury Canvas Wrapper Frame -->
                <div class="relative w-full max-w-md sm:max-w-lg aspect-[4/5] p-4 bg-white border border-stone-200/60 shadow-xl rounded-2xl group overflow-hidden bg-stone-200">
                    <div class="w-full h-full rounded-xl overflow-hidden relative">
                        <img src="https://images.unsplash.com/photo-1604351882297-84ba33247f61?q=80&w=600&auto=format&fit=crop" 
                             alt="Traditional Indian Marriage Elements" 
                             class="w-full h-full object-cover transform group-hover:scale-102 transition duration-700 filter brightness-[0.93] contrast-[1.02]">
                        <div class="absolute inset-0 bg-gradient-to-t from-stone-950/30 via-transparent to-transparent"></div>
                    </div>
                </div>

                <!-- REINVENTED SHIELD OVERLAY -->
                <div class="absolute -bottom-6 -left-4 sm:left-6 lg:-left-12 bg-stone-950 text-white p-6 rounded-2xl border border-white/10 shadow-2xl max-w-[210px] transform hover:rotate-1 hover:scale-105 transition-all duration-300 group cursor-pointer"
                     x-data="{ count: 450 }" @mouseenter="count = count + 1">
                    <div class="space-y-4">
                        <div class="flex justify-between items-center border-b border-white/10 pb-2">
                            <span class="text-[9px] uppercase tracking-[0.2em] text-amber-400 font-bold">Bureau Status</span>
                            <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-sm shadow-emerald-500/50"></div>
                        </div>
                        <div class="space-y-1">
                            <div class="text-2xl font-serif text-white tracking-tight font-medium flex items-center gap-1.5">
                                <span x-text="count"></span><span class="text-amber-500 text-lg">+</span>
                            </div>
                            <p class="text-[10px] uppercase tracking-wider text-stone-400 font-medium leading-normal">Verified Families Connected Globally</p>
                        </div>
                        <div class="bg-white/5 border border-white/10 px-3 py-1.5 rounded-lg text-center text-[9px] uppercase tracking-widest font-bold text-amber-400/90 group-hover:bg-amber-600 group-hover:text-white transition duration-300">
                            Verified Bureau
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Interactive Profiles Grid Dashboard -->
    <main id="directory" class="max-w-7xl mx-auto px-4 sm:px-6 py-20" x-data="{ activeSect: 'all' }">
        
        <div class="text-center mb-12">
            <span class="text-xs uppercase tracking-widest font-bold text-amber-700 bg-amber-50 px-3 py-1 rounded border border-amber-200/50">Curated Matches</span>
            <h2 class="text-3xl font-light text-stone-900 tracking-tight mt-3">Verified Prospects</h2>
        </div>

        <!-- Modernist Responsive Filter Control Tabs -->
        <div class="flex space-x-1 max-w-xs sm:max-w-md mx-auto mb-16 bg-stone-200/50 p-1 sm:p-1.5 rounded-full border border-stone-200/20 backdrop-blur-sm shadow-inner">
            <button @click="activeSect = 'all'" :class="activeSect === 'all' ? 'bg-white text-stone-950 shadow-sm font-semibold' : 'text-stone-500 hover:text-stone-800 font-medium'" class="w-full py-2 rounded-full text-[11px] sm:text-xs uppercase tracking-wider transition-all duration-300">All</button>
            <button @click="activeSect = 'Digambar'" :class="activeSect === 'Digambar' ? 'bg-white text-stone-950 shadow-sm font-semibold' : 'text-stone-500 hover:text-stone-800 font-medium'" class="w-full py-2 rounded-full text-[11px] sm:text-xs uppercase tracking-wider transition-all duration-300">Digambar</button>
            <button @click="activeSect = 'Shvetambar'" :class="activeSect === 'Shvetambar' ? 'bg-white text-stone-950 shadow-sm font-semibold' : 'text-stone-500 hover:text-stone-800 font-medium'" class="w-full py-2 rounded-full text-[11px] sm:text-xs uppercase tracking-wider transition-all duration-300">Shvetambar</button>
        </div>

        <!-- Fully Responsive Profiles Grid Container -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
            <% if (Array.isArray(profiles) && profiles.length > 0) { %>
                <% profiles.forEach((profile, index) => { %>
                    <div 
                        x-show="activeSect === 'all' || activeSect === '<%= profile.acf?.sect %>'"
                        x-transition:enter="transition ease-out duration-500 cubic-bezier(0.16, 1, 0.3, 1)"
                        x-transition:enter-start="opacity-0 translate-y-6 scale-98"
                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                        class="bg-white rounded-2xl sm:rounded-3xl p-5 sm:p-7 border border-stone-200/50 hover:border-amber-700/30 hover:shadow-2xl hover:shadow-stone-200/60 transition-all duration-500 flex flex-col justify-between group transform hover:-translate-y-1"
                    >
                        <div>
                            <!-- Header Info Panel -->
                            <div class="flex justify-between items-center mb-5">
                                <span class="text-[9px] sm:text-[10px] font-bold px-2.5 py-1 bg-emerald-50 text-emerald-800 rounded-full border border-emerald-200/20 tracking-wider uppercase flex items-center gap-1.5 shadow-inner">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                    Verified
                                </span>
                                <span class="text-[11px] text-stone-400 font-mono tracking-tight bg-stone-50 px-2 py-0.5 rounded border border-stone-100">Ref: JW-<%= profile.acf?.profile_id || '000' %></span>
                            </div>
                            
                            <!-- Identification Data Titles -->
                            <h2 class="text-lg sm:text-xl font-semibold text-stone-900 mb-1 group-hover:text-amber-800 transition duration-300"><%= profile.title?.rendered %></h2>
                            <p class="text-[11px] text-stone-400 font-bold uppercase tracking-widest mb-4 flex items-center gap-2">
                                <span><%= profile.acf?.sect || 'General' %></span>
                                <span class="w-1 h-1 rounded-full bg-stone-300"></span>
                                <span class="text-stone-500">Gothra: <%= profile.acf?.gothra || 'N/A' %></span>
                            </p>
                            
                            <!-- Core Structured Properties List -->
                            <div class="space-y-3 text-xs sm:text-sm text-stone-600 bg-stone-50/70 p-4 sm:p-5 rounded-xl sm:rounded-2xl border border-stone-200/30 mb-6 sm:mb-8 shadow-inner">
                                <div class="flex justify-between items-center"><span class="text-stone-400 font-light">Age / Height</span> <span class="font-medium text-stone-800"><%= profile.acf?.age || 'N/A' %> Yrs / <%= profile.acf?.height || 'N/A' %></span></div>
                                <div class="flex justify-between items-center"><span class="text-stone-400 font-light">Education</span> <span class="font-medium text-stone-800 tracking-tight text-right max-w-[180px] truncate"><%= profile.acf?.education || 'N/A' %></span></div>
                                <div class="flex justify-between items-center"><span class="text-stone-400 font-light">Profession</span> <span class="font-medium text-stone-800 text-right max-w-[180px] truncate"><%= profile.acf?.profession || 'N/A' %></span></div>
                                <div class="flex justify-between items-center"><span class="text-stone-400 font-light">Diet Profile</span> <span class="font-medium text-stone-700 text-[11px] px-2 py-0.5 bg-white border border-stone-200 rounded-md"><%= profile.acf?.diet || 'N/A' %></span></div>
                                <div class="flex justify-between items-center"><span class="text-stone-400 font-light">Location</span> <span class="font-medium text-stone-800"><%= profile.acf?.location || 'N/A' %></span></div>
                            </div>
                        </div>

                        <!-- One-Click Inquiry Routing to WhatsApp Support Team -->
                        <a href="https://wa.me/918983269657?text=Hello%20Jain's%20Wedding,%20I%20am%20interested%20in%20learning%20more%20about%20Profile%20Ref:%20JW-<%= profile.acf?.profile_id || '000' %>" 
                           target="_blank"
                           class="w-full text-center bg-stone-950 text-white py-3 sm:py-3.5 rounded-xl sm:rounded-2xl text-[11px] sm:text-xs font-semibold uppercase tracking-widest hover:bg-amber-700 shadow-md hover:shadow-amber-700/20 transition-all duration-300 block">
                            Inquire via Bureau
                        </a>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <!-- Dynamic Premium Cinematic Video Gallery Showcase Canvas -->
    <section class="bg-[#141311] text-stone-100 py-16 sm:py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(#383530_1px,transparent_1px)] [background-size:24px_24px] opacity-30 pointer-events-none"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-8 relative">
            <div class="text-center mb-12 sm:mb-20">
                <span class="text-amber-500 text-[10px] sm:text-xs font-bold tracking-widest uppercase bg-amber-500/10 px-4 py-1.5 rounded-full border border-amber-500/20">Celebrations</span>
                <h2 class="text-2xl sm:text-4xl md:text-5xl font-light font-serif tracking-tight mt-4 text-white">Union Testimonials</h2>
                <p class="text-stone-500 text-xs sm:text-sm max-w-sm mx-auto mt-3 font-light px-4">Documented verification stories from families who discovered matches with our administrative help.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
                <% if (Array.isArray(stories) && stories.length > 0) { %>
                    <% stories.forEach(story => { %>
                        <div class="bg-stone-900/40 border border-stone-800/60 rounded-2xl sm:rounded-3xl p-4 sm:p-5 flex flex-col justify-between backdrop-blur-md shadow-xl hover:border-amber-600/30 transition duration-300 group">
                            <div class="aspect-video bg-black rounded-xl sm:rounded-2xl mb-4 sm:mb-5 overflow-hidden relative shadow-inner border border-stone-800/80 group-hover:scale-[1.01] transition duration-500">
                                <%- story.acf?.video_embed_code %>
                            </div>
                            <div>
                                <h3 class="font-medium text-stone-200 text-base sm:text-lg tracking-tight group-hover:text-amber-400 transition duration-300"><%= story.title?.rendered %></h3>
                                <p class="text-[11px] sm:text-xs text-stone-500 mt-1 flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
                                    Matched in <%= story.acf?.wedding_year || 'N/A' %>
                                </p>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Fixed Floating WhatsApp Mobile Action Anchor -->
    <a href="https://wa.me/918983269657" target="_blank" class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-white p-3.5 rounded-full shadow-xl shadow-green-600/20 hover:scale-110 transition duration-300 flex items-center justify-center">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397 0 11.948 0c3.179.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.239 3.482 8.42-.003 6.597-5.339 11.946-11.89 11.946-2.005-.001-3.973-.509-5.715-1.477L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.528 1.986 14.066.96 11.453.96c-5.447 0-9.866 4.372-9.87 9.802 0 1.714.457 3.39 1.32 4.869l-.993 3.63 3.737-.967zm12.388-7.925c-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414-.074-.124-.272-.198-.57-.347z"/></svg>
    </a>

</body>
</html>